    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0"
  },
  "jest": {
    "testTimeout": 30000,
    "testPathIgnorePatterns": ["/node_modules/", "__tests__/helpers/"]
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "mongodb-memory-server": "^9.1.0",
    "supertest": "^6.3.3",
    "nodemon": "^2.0.20"
  }
