  "description": "Backend for prompt injection learning app",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "E2E_MODE=true jest --runInBand --coverage",
    "test:watch": "E2E_MODE=true jest --runInBand --watch"
